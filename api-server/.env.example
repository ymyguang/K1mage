PORT=3001
NODE_ENV=development

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=k1mage
MYSQL_CONNECTION_LIMIT=10

# WeChat Mini Program
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
DEV_WECHAT_LOGIN=false
DEV_WECHAT_OPENID=dev_openid

# Auth and points
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=30d
REGISTER_BONUS_POINTS=3
DEFAULT_IMAGE_COST_POINTS=1
ENABLE_IMAGE_MOCK=false
PUBLIC_API_BASE_URL=http://127.0.0.1:3001
HIDDEN_TEMPLATE_IDS=

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.apimart.ai/v1
OPENAI_IMAGE_RESOLUTION=1k
APIMART_IMAGE_INITIAL_WAIT_MS=2000
APIMART_IMAGE_POLL_INTERVAL_MS=3000
APIMART_IMAGE_MAX_WAIT_MS=300000
TOAPIS_IMAGE_INITIAL_WAIT_MS=2000
TOAPIS_IMAGE_POLL_INTERVAL_MS=3000
TOAPIS_IMAGE_MAX_WAIT_MS=300000

# 阿里巴巴通义万相
TONGYI_API_KEY=your_tongyi_key_here

# 默认模型配置
DEFAULT_PROVIDER=gemini
DEFAULT_MODEL=gemini-2.5-flash-image
