{
  "name": "k1mage-api-server",
  "version": "2.0.0",
  "description": "Multi-model unified API server for K1mage",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:smoke": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=smoke",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=unit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "abort-controller": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "global-agent": "^4.1.3",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
