page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  min-height: 0;
}

.page-shell {
  padding: 28rpx 28rpx 56rpx;
}

.back-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  margin-bottom: 22rpx;
  padding: 0 22rpx 0 16rpx;
  border: 2rpx solid rgba(119, 101, 135, 0.16);
  border-radius: 999rpx;
  color: #776587;
  background: #FFFFFF;
  box-shadow: 0 10rpx 24rpx rgba(119, 101, 135, 0.08);
  font-size: 25rpx;
  font-weight: 900;
}

.back-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
  font-size: 34rpx;
  line-height: 28rpx;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-radius: 32rpx;
  color: #FFFFFF;
  background: #776587;
  box-shadow: 0 22rpx 52rpx rgba(119, 101, 135, 0.2);
}

.summary-label {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 800;
}

.summary-points {
  margin-top: 8rpx;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-count {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #776587;
  background: #FFFFFF;
  font-size: 24rpx;
  font-weight: 900;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.record-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(119, 101, 135, 0.16);
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 34rpx rgba(119, 101, 135, 0.08);
}

.record-image,
.record-placeholder {
  flex: none;
  width: 148rpx;
  height: 148rpx;
  border-radius: 22rpx;
  background: rgba(119, 101, 135, 0.08);
}

.record-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #776587;
  font-size: 24rpx;
  font-weight: 900;
}

.record-body {
  flex: 1;
  min-width: 0;
}

.record-top,
.record-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.record-template {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #776587;
  font-size: 28rpx;
  font-weight: 900;
}

.record-status {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.status-success {
  color: #246b4b;
  background: rgba(36, 107, 75, 0.1);
}

.status-failed {
  color: #9b3d42;
  background: rgba(155, 61, 66, 0.1);
}

.status-pending {
  color: #776587;
  background: rgba(119, 101, 135, 0.1);
}

.record-meta {
  overflow: hidden;
  margin-top: 10rpx;
  color: rgba(119, 101, 135, 0.62);
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-bottom {
  margin-top: 12rpx;
  color: rgba(119, 101, 135, 0.78);
  font-size: 23rpx;
  font-weight: 800;
}

.record-error {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #9b3d42;
  font-size: 22rpx;
  line-height: 1.4;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-action {
  margin-top: 10rpx;
  color: #776587;
  font-size: 23rpx;
  font-weight: 900;
}

.empty-card,
.error-card {
  margin-top: 24rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(119, 101, 135, 0.16);
  border-radius: 28rpx;
  color: #776587;
  background: #FFFFFF;
  box-shadow: 0 12rpx 34rpx rgba(119, 101, 135, 0.08);
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 10rpx;
  color: rgba(119, 101, 135, 0.68);
  font-size: 24rpx;
}
