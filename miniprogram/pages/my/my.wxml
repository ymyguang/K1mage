<navigation-bar title="我的" color="#776587" background="#FFFFFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="page-shell">
    <view class="profile-card">
      <image
        wx:if="{{user && user.avatar_url}}"
        class="avatar"
        src="{{user.avatar_url}}"
        mode="aspectFill"
      ></image>
      <image wx:else class="avatar" src="/assets/brand/k1-avatar.png" mode="aspectFill"></image>

      <view class="profile-main">
        <view class="profile-name">{{user ? user.displayName : '未登录'}}</view>
        <view class="profile-subtitle">{{user ? '欢迎回来' : '登录后查看积分和记录'}}</view>
      </view>
    </view>

    <view class="points-card">
      <view>
        <view class="points-label">剩余积分</view>
        <view class="points-value">{{user ? (user.points || 0) : '-'}}</view>
      </view>
      <button wx:if="{{!user}}" class="primary-button" loading="{{isLoggingIn}}" bindtap="handleLogin">
        微信登录
      </button>
    </view>

    <view class="menu-card" wx:if="{{user}}">
      <view class="menu-row" bindtap="openHistory">
        <text>生成记录</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="handleLogout">
        <text>退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="error-card" wx:if="{{errorMessage}}">
      {{errorMessage}}
    </view>
  </view>
</scroll-view>
