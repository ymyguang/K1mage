page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  min-height: 0;
}

.page-shell {
  padding: 28rpx 28rpx 150rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  min-height: 250rpx;
  padding: 34rpx 36rpx 30rpx;
  border: 2rpx solid rgba(119, 101, 135, 0.16);
  border-radius: 38rpx;
  color: #FFFFFF;
  background: #776587;
  box-shadow: 0 24rpx 60rpx rgba(119, 101, 135, 0.22);
}

.hero-logo {
  position: relative;
  z-index: 1;
  display: block;
  width: 198rpx;
  height: 78rpx;
  margin-left: -2rpx;
}

.hero-points {
  position: absolute;
  top: 34rpx;
  right: 36rpx;
  z-index: 2;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  color: #FFFFFF;
}

.points-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 62rpx;
  color: #776587;
}

.points-strip-logo {
  flex: none;
  width: 174rpx;
  height: 54rpx;
}

.points-strip-balance {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 8rpx;
}

.points-strip-title,
.points-strip-label {
  color: rgba(119, 101, 135, 0.68);
  font-size: 24rpx;
  font-weight: 800;
}

.points-strip-value {
  color: #776587;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-points-title {
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  font-weight: 800;
}

.hero-points-value {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-points-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 800;
}

.account-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 36rpx;
  padding: 0;
}

.account-card-logged-in {
  margin-top: 78rpx;
}

.account-main {
  flex: 1;
  min-width: 0;
}

.account-title {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.account-copy {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.4;
}

.account-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
}

.account-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 168rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.account-button.primary {
  color: #776587;
  background: #FFFFFF;
}

.account-button.ghost {
  color: #FFFFFF;
  min-width: 96rpx;
  background: rgba(255, 255, 255, 0.14);
}

.section {
  margin-top: 30rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(119, 101, 135, 0.16);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 48rpx rgba(119, 101, 135, 0.1);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #776587;
}

.section-note {
  font-size: 24rpx;
  color: rgba(119, 101, 135, 0.68);
}

.template-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.template-row-card {
  display: flex;
  align-items: center;
  min-height: 196rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(119, 101, 135, 0.14);
  border-radius: 30rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 30rpx rgba(119, 101, 135, 0.08);
}

.template-row-card:active {
  border-color: #776587;
  background: rgba(119, 101, 135, 0.06);
}

.template-row-cover {
  flex: none;
  width: 168rpx;
  height: 168rpx;
  border-radius: 24rpx;
  background: rgba(119, 101, 135, 0.08);
}

.template-row-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #776587;
  font-weight: 900;
  font-size: 48rpx;
}

.template-row-body {
  flex: 1;
  min-width: 0;
  padding: 0 18rpx;
}

.template-row-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.template-row-index {
  color: rgba(119, 101, 135, 0.5);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.template-row-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 900;
  color: #776587;
}

.template-row-desc {
  display: -webkit-box;
  margin-top: 12rpx;
  overflow: hidden;
  color: rgba(119, 101, 135, 0.72);
  font-size: 23rpx;
  line-height: 1.45;
  white-space: normal;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.template-row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.template-row-meta,
.template-row-price,
.template-row-featured {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.template-row-meta {
  color: #FFFFFF;
  background: #776587;
}

.template-row-price {
  color: #776587;
  background: rgba(119, 101, 135, 0.1);
}

.template-row-featured {
  color: #FFFFFF;
  background: rgba(119, 101, 135, 0.72);
}

.template-row-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  color: #776587;
  background: rgba(119, 101, 135, 0.08);
}

.template-row-arrow-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  color: #776587;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
  transform: translateY(-2rpx);
}

.error-card {
  margin-top: 24rpx;
  padding: 22rpx 26rpx;
  border: 2rpx solid rgba(119, 101, 135, 0.24);
  border-radius: 24rpx;
  color: #776587;
  background: #FFFFFF;
  font-size: 25rpx;
  line-height: 1.55;
}
